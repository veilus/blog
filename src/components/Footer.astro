---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-brand">
			<p class="copyright">
				&copy; {today.getFullYear()} Veilus. All rights reserved.
			</p>
			<p class="tagline">Open-source anti-detect browser</p>
		</div>
		<div class="footer-links">
			<a href="https://veilus.io">Website</a>
			<a href="https://docs.veilus.io">Docs</a>
			<a
				href="https://github.com/nicholasgriffintn/veilus"
				target="_blank"
				rel="noopener noreferrer">GitHub</a
			>
			<a
				href="https://x.com/veilusbrowser"
				target="_blank"
				rel="noopener noreferrer">X</a
			>
			<a
				href="https://t.me/veilusbrowser"
				target="_blank"
				rel="noopener noreferrer">Telegram</a
			>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 2.5em 1em 3em 1em;
		background: #0b0f1a;
		border-top: 1px solid #30363d;
		text-align: center;
	}
	.footer-content {
		max-width: 960px;
		margin: 0 auto;
	}
	.footer-brand {
		margin-bottom: 1em;
	}
	.copyright {
		margin: 0;
		color: #9ba5b0;
		font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 0.9em;
	}
	.tagline {
		margin: 0.25em 0 0 0;
		color: #636c76;
		font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 0.8em;
		font-style: italic;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 1.5em;
	}
	.footer-links a {
		color: #9ba5b0;
		text-decoration: none;
		font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
		font-size: 0.85em;
		font-weight: 600;
		transition: color 0.15s ease;
	}
	.footer-links a:hover {
		color: #00d4ff;
	}
</style>
