---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.welcome {
				margin-bottom: 3em;
			}
			.welcome h1 {
				font-size: 2.2em;
				margin-bottom: 0.5em;
			}
			.welcome p {
				color: var(--text-secondary);
				font-size: 1.1em;
				max-width: 60ch;
			}
			.welcome .accent {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="welcome">
				<h1>Welcome to <span class="accent">Veilus Blog</span></h1>
				<p>
					Insights, updates, and technical deep-dives from the team
					building Veilus — an open-source anti-detect browser powered
					by a custom Chromium engine. We write about browser
					fingerprinting, privacy engineering, and the journey of
					building a transparent alternative to closed-source
					solutions.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
