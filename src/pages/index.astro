---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.welcome {
				margin-bottom: 3em;
			}
			.welcome h1 {
				font-size: 2.2em;
				margin-bottom: 0.5em;
			}
			.welcome p {
				color: var(--text-secondary);
				font-size: 1.1em;
				max-width: 60ch;
			}
			.welcome .accent {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="welcome">
				<h1><span class="accent">Veilus</span> Blog</h1>
				<p>
					Managing multiple online accounts shouldn't mean getting
					banned. Veilus is a free anti-detect browser that gives each
					profile a unique fingerprint — so every account looks like
					it's running on a different computer. We write about
					multi-account management, browser fingerprinting, and
					automation.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
